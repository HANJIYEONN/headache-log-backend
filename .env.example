# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워주세요 (.env는 git에 안 올라가요)

# 로컬 개발: MySQL (charset=utf8mb4 로 한글·이모지 안전)
DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/headache_log?charset=utf8mb4

# 배포: TiDB Cloud (MySQL 호환) — 배포 서버의 .env에서는 이 형식을 사용
# 값은 TiDB Cloud 콘솔 → Connect 에서 확인 (비밀번호의 특수문자는 URL 인코딩 필요)
# DATABASE_URL=mysql+pymysql://<USER>:<PASSWORD>@<HOST>:4000/headache_log?charset=utf8mb4&ssl_ca=/etc/ssl/certs/ca-certificates.crt&ssl_verify_cert=true&ssl_verify_identity=true

# Google OAuth 클라이언트 ID (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=

# 자체 JWT 서명 비밀키 — python3 -c "import secrets; print(secrets.token_hex(32))" 로 생성
JWT_SECRET=
